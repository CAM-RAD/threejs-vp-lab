# Cloudflare Pages headers
# HTML files: never cache (instant updates on deploy)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/scenes/**/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets: cache aggressively (GLB models, images)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
